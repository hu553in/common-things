version: 2
{% if enable_docker | default(false, true) %}

registries:
  ghcr:
    type: docker-registry
    url: https://ghcr.io
    username: '${{github.repository_owner}}'
    password: '${{secrets.GITHUB_TOKEN}}'
{% endif %}

updates:
{% if enable_github_actions | default(false, true) %}

  - package-ecosystem: github-actions
    directory: '/'
    schedule:
      interval: daily
    open-pull-requests-limit: 5
    assignees:
      - hu553in
    commit-message:
      prefix: 'deps(dependabot):'
    allow:
      - dependency-type: all
    groups:
      patch-and-minor:
        update-types:
          - patch
          - minor
      major:
        update-types:
          - major
{% endif %}
{% if enable_docker | default(false, true) %}

  - package-ecosystem: docker
    directories:
      - '/'
{% for d in extra_docker_directories | default([], true) %}
      - '{{ d }}'
{% endfor %}
    schedule:
      interval: daily
    open-pull-requests-limit: 5
    assignees:
      - hu553in
    commit-message:
      prefix: 'deps(dependabot):'
    registries:
      - ghcr
    allow:
      - dependency-type: all
    groups:
      patch-and-minor:
        update-types:
          - patch
          - minor
      major:
        update-types:
          - major
{% endif %}
